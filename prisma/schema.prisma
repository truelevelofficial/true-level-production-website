generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  OWNER
  ADMIN
  ACCOUNTANT
  LEGAL
  VIEWER
}

enum BookingType {
  GOOGLE_MEETING
  COMPANY_MEETING
  STUDIO
  SERVICE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  VODAFONE_CASH
  INSTAPAY
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  CANCELLED
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

enum ExpenseCategory {
  RENT
  SALARIES
  EQUIPMENT
  ADS
  UTILITIES
  TRANSPORTATION
  FREELANCERS
  MAINTENANCE
  OFFICE_SUPPLIES
  OTHER
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum ContractType {
  STUDIO_RENTAL
  VIDEO_PRODUCTION
  UGC_CREATOR_CAMPAIGN
  EVENT_COVERAGE
  MONTHLY_CONTENT_MANAGEMENT
  GENERAL_SERVICE
  CONTENT_CREATORS
  CONTENT_CREATORS_NDA
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  provider     String   @default("credentials")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String    @id @default(cuid())
  fullName    String
  companyName String?
  phone       String
  whatsapp    String?
  email       String    @unique
  address     String?
  taxId       String?
  commercialRegistrationNumber String?
  clientType  String?
  leadSource  String?
  industry    String?
  companySize String?
  decisionMaker String?
  socialLinks String?
  pipelineStatus String?
  assignedTeamMember String?
  lostReason  String?
  lastContactDate DateTime?
  notes       String?
  bookings    Booking[]
  invoices    Invoice[]
  payments    Payment[]
  expenses    Expense[]
  contracts   Contract[]
  notifications Notification[]
  quotations   Quotation[]
  projects     Project[]
  portalUser   ClientPortalUser?
  fileAttachments FileAttachment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([phone])
}

model Booking {
  id              String        @id @default(cuid())
  type            BookingType
  status          BookingStatus @default(PENDING)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  durationHours   Int?
  serviceType     String?
  studioSetup     String?
  bookingSubtype  String?
  meetingType     String?
  meetingLocation String?
  assignedTeamMember String?
  bookingPurpose  String?
  peopleCount     Int?
  price           Decimal?      @db.Decimal(12, 2)
  deposit         Decimal?      @db.Decimal(12, 2)
  discount        Decimal?      @db.Decimal(12, 2)
  remainingAmount Decimal?      @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(UNPAID)
  meetingLink     String?
  googleEventId   String?
  notes           String?
  internalNotes   String?
  invoices        Invoice[]
  quotations      Quotation[]
  payments        Payment[]
  contracts       Contract[]
  notifications   Notification[]
  projects        Project[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([type, status])
  @@index([date])
  @@index([studioSetup, startTime, endTime])
}

model StudioSetup {
  id                  String   @id @default(cuid())
  name                String   @unique
  defaultHourlyPrice  Decimal? @db.Decimal(12, 2)
  defaultHalfDayPrice Decimal? @db.Decimal(12, 2)
  defaultFullDayPrice Decimal? @db.Decimal(12, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id             String               @id @default(cuid())
  invoiceNo      String               @unique
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bookingId      String?
  booking        Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contractId     String?
  contract       Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  status         InvoiceStatus        @default(DRAFT)
  paymentStatus  InvoicePaymentStatus @default(UNPAID)
  invoiceDate    DateTime             @default(now())
  dueDate        DateTime?
  currency       String               @default("EGP")
  subtotal       Decimal              @db.Decimal(12, 2)
  discount       Decimal              @db.Decimal(12, 2)
  taxRate        Decimal              @db.Decimal(5, 2)
  taxAmount      Decimal              @db.Decimal(12, 2)
  total          Decimal              @db.Decimal(12, 2)
  paidAmount     Decimal              @db.Decimal(12, 2)
  remainingAmount Decimal             @db.Decimal(12, 2)
  notes          String?
  terms          String?
  items          InvoiceItem[]
  payments       Payment[]
  fileAttachments FileAttachment[]
  sentAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(OTHER)
  status      PaymentStatus @default(PAID)
  description String?
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId   String?
  booking     Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  invoiceId   String?
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  method      PaymentMethod   @default(OTHER)
  description String
  clientId    String?
  client      Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Contract {
  id         String         @id @default(cuid())
  type       ContractType
  status     ContractStatus @default(DRAFT)
  title      String
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId  String?
  booking    Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  body       String
  totalPrice Decimal?       @db.Decimal(12, 2)
  deposit    Decimal?       @db.Decimal(12, 2)
  remaining  Decimal?       @db.Decimal(12, 2)
  signedAt  DateTime?
  projects   Project[]
  invoices   Invoice[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ContractTemplate {
  id        String       @id @default(cuid())
  type      ContractType @unique
  title     String
  body      String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model CompanySettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String?
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Quotation {
  id             String           @id @default(cuid())
  quotationNo    String?
  status         String           @default("DRAFT")
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId      String?
  booking        Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items          QuotationItem[]
  totalAmount    Decimal          @db.Decimal(12, 2)
  discount       Decimal          @default(0) @db.Decimal(12, 2)
  taxRate        Decimal          @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal          @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal          @default(0) @db.Decimal(12, 2)
  currency       String           @default("EGP")
  serviceType    String?
  notes          String?
  terms          String?
  validUntil     DateTime?
  sentAt         DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal   @db.Decimal(12, 2)
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
}

model Project {
  id          String     @id @default(cuid())
  status      String     @default("ACTIVE")
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId   String?
  booking     Booking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  contractId  String?
  contract    Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  invoices    Invoice[]
  quotations  Quotation[]
  title       String
  description String?
  projectType String?
  budget      Decimal?   @db.Decimal(12, 2)
  actualCost  Decimal?   @db.Decimal(12, 2)
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  assignedTo  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tasks       Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      String     @default("PENDING")
  priority    String     @default("MEDIUM")
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model TeamMember {
  id               String                    @id @default(cuid())
  name             String
  role             String?
  department       String?
  email            String?
  phone            String?
  active           Boolean                   @default(true)
  capacity         Int?                      @default(100)
  performanceScore Float?
  availability     String?                   @default("AVAILABLE")
  notes            String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  tasks            WorkflowTask[]
  projects         WorkflowProject[]         @relation("ProjectOwner")
}

model WorkflowProject {
  id          String             @id @default(cuid())
  title       String
  clientId    String?
  clientName  String?
  serviceType String?
  stage       String             @default("NEW_LEAD")
  priority    String             @default("NORMAL")
  ownerId     String?
  dueDate     DateTime?
  notes       String?
  quotationId String?
  contractId  String?
  invoiceId   String?
  bookingId   String?
  archived    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       TeamMember?         @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks       WorkflowTask[]
  approvals   WorkflowApproval[]
  deliveries  WorkflowDelivery[]
  contentProductions  ContentProduction[]
  approvalRequests    ApprovalRequest[]
  workflowNotifications WorkflowNotification[]
  fileAttachments     FileAttachment[]
}

model WorkflowTask {
  id          String          @id @default(cuid())
  title       String
  description String?
  projectId   String?
  assigneeId  String?
  department  String?
  status      String          @default("TODO")
  priority    String          @default("NORMAL")
  dueDate     DateTime?
  notes       String?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     WorkflowProject?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    TeamMember?           @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  workflowNotifications WorkflowNotification[]
}

model WorkflowApproval {
  id         String          @id @default(cuid())
  projectId  String?
  title      String
  clientName String?
  status     String          @default("NOT_SENT")
  sentDate   DateTime?
  dueDate    DateTime?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  project    WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model WorkflowDelivery {
  id              String          @id @default(cuid())
  projectId       String?
  title           String
  deliverableType String?
  deliveryLink    String?
  status          String          @default("PREPARING")
  deliveryDate    DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  project         WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ─── Content Production Pipeline ───

model ContentProduction {
  id          String             @id @default(cuid())
  projectId   String?
  title       String
  contentType String             @default("REEL")
  stage       String             @default("IDEA")
  platform    String?
  script      String?
  dueDate     DateTime?
  publishedAt DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     WorkflowProject?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ─── Approval Requests ───

model ApprovalRequest {
  id          String          @id @default(cuid())
  type        String          @default("QUOTATION")
  title       String
  status      String          @default("PENDING")
  requestedBy String?
  approvedBy  String?
  rejectedBy  String?
  notes       String?
  projectId   String?
  quotationId String?
  contractId  String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ─── Workflow Notifications ───

model WorkflowNotification {
  id            String          @id @default(cuid())
  type          String          @default("TASK_ASSIGNED")
  title         String
  message       String?
  projectId     String?
  taskId        String?
  targetEmail   String?
  read          Boolean         @default(false)
  readAt        DateTime?
  autoTriggered Boolean         @default(false)
  createdAt     DateTime        @default(now())
  project       WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task          WorkflowTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// ─── Activity Log ───

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  description String?
  metadata    String?  // JSON payload
  userId      String?
  userName    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action])
}

// ─── File Attachments ───

model FileAttachment {
  id           String          @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String?
  fileSize     Int?
  url          String?
  projectId    String?
  project      WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId     String?
  client       Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoiceId    String?
  invoice      Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  uploaderName String?
  notes        String?
  folder       String?         @default("General")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([projectId])
  @@index([clientId])
  @@index([folder])
}

// ─── Client Portal ───

model ClientPortalUser {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clientId])
  @@unique([email])
}

// ─── Automation Rules ───

model AutomationRule {
  id        String   @id @default(cuid())
  name      String
  trigger   String
  action    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Reports ───

model Report {
  id        String   @id @default(cuid())
  type      String
  name      String
  config    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Roles & Permissions ───

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource  String
  action    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, resource, action])
}

// ─── Studio Rooms & Equipment ───

model StudioRoom {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("STUDIO")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudioEquipment {
  id        String   @id @default(cuid())
  name      String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Creator {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  specialty String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
