generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  OWNER
  ADMIN
  ACCOUNTANT
  LEGAL
  VIEWER
}

enum BookingType {
  GOOGLE_MEETING
  COMPANY_MEETING
  STUDIO
  SERVICE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  VODAFONE_CASH
  INSTAPAY
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  CANCELLED
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

enum ExpenseCategory {
  RENT
  SALARIES
  EQUIPMENT
  ADS
  UTILITIES
  TRANSPORTATION
  FREELANCERS
  MAINTENANCE
  OFFICE_SUPPLIES
  OTHER
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum ContractType {
  STUDIO_RENTAL
  VIDEO_PRODUCTION
  UGC_CREATOR_CAMPAIGN
  EVENT_COVERAGE
  MONTHLY_CONTENT_MANAGEMENT
  GENERAL_SERVICE
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  provider     String   @default("credentials")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String    @id @default(cuid())
  fullName    String
  companyName String?
  phone       String
  whatsapp    String?
  email       String    @unique
  address     String?
  taxId       String?
  commercialRegistrationNumber String?
  clientType  String?
  leadSource  String?
  pipelineStatus String?
  assignedTeamMember String?
  lostReason  String?
  lastContactDate DateTime?
  notes       String?
  bookings    Booking[]
  invoices    Invoice[]
  payments    Payment[]
  expenses    Expense[]
  contracts   Contract[]
  notifications Notification[]
  quotations   Quotation[]
  projects     Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([phone])
}

model Booking {
  id              String        @id @default(cuid())
  type            BookingType
  status          BookingStatus @default(PENDING)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  durationHours   Int?
  serviceType     String?
  studioSetup     String?
  bookingSubtype  String?
  meetingType     String?
  meetingLocation String?
  assignedTeamMember String?
  bookingPurpose  String?
  peopleCount     Int?
  price           Decimal?      @db.Decimal(12, 2)
  deposit         Decimal?      @db.Decimal(12, 2)
  discount        Decimal?      @db.Decimal(12, 2)
  remainingAmount Decimal?      @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(UNPAID)
  meetingLink     String?
  googleEventId   String?
  notes           String?
  internalNotes   String?
  invoices        Invoice[]
  quotations      Quotation[]
  payments        Payment[]
  contracts       Contract[]
  notifications   Notification[]
  projects        Project[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([type, status])
  @@index([date])
  @@index([studioSetup, startTime, endTime])
}

model StudioSetup {
  id                  String   @id @default(cuid())
  name                String   @unique
  defaultHourlyPrice  Decimal? @db.Decimal(12, 2)
  defaultHalfDayPrice Decimal? @db.Decimal(12, 2)
  defaultFullDayPrice Decimal? @db.Decimal(12, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id             String               @id @default(cuid())
  invoiceNo      String               @unique
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bookingId      String?
  booking        Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contractId     String?
  contract       Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  status         InvoiceStatus        @default(DRAFT)
  paymentStatus  InvoicePaymentStatus @default(UNPAID)
  invoiceDate    DateTime             @default(now())
  dueDate        DateTime?
  currency       String               @default("EGP")
  subtotal       Decimal              @db.Decimal(12, 2)
  discount       Decimal              @db.Decimal(12, 2)
  taxRate        Decimal              @db.Decimal(5, 2)
  taxAmount      Decimal              @db.Decimal(12, 2)
  total          Decimal              @db.Decimal(12, 2)
  paidAmount     Decimal              @db.Decimal(12, 2)
  remainingAmount Decimal             @db.Decimal(12, 2)
  notes          String?
  terms          String?
  items          InvoiceItem[]
  payments       Payment[]
  sentAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(OTHER)
  status      PaymentStatus @default(PAID)
  description String?
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId   String?
  booking     Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  invoiceId   String?
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  method      PaymentMethod   @default(OTHER)
  description String
  clientId    String?
  client      Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Contract {
  id         String         @id @default(cuid())
  type       ContractType
  status     ContractStatus @default(DRAFT)
  title      String
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId  String?
  booking    Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  body       String
  totalPrice Decimal?       @db.Decimal(12, 2)
  deposit    Decimal?       @db.Decimal(12, 2)
  remaining  Decimal?       @db.Decimal(12, 2)
  signedAt  DateTime?
  projects   Project[]
  invoices   Invoice[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ContractTemplate {
  id        String       @id @default(cuid())
  type      ContractType @unique
  title     String
  body      String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model CompanySettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String?
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Quotation {
  id             String           @id @default(cuid())
  quotationNo    String?
  status         String           @default("DRAFT")
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId      String?
  booking        Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items          QuotationItem[]
  totalAmount    Decimal          @db.Decimal(12, 2)
  discount       Decimal          @default(0) @db.Decimal(12, 2)
  taxRate        Decimal          @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal          @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal          @default(0) @db.Decimal(12, 2)
  currency       String           @default("EGP")
  serviceType    String?
  notes          String?
  terms          String?
  validUntil     DateTime?
  sentAt         DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal   @db.Decimal(12, 2)
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
}

model Project {
  id          String     @id @default(cuid())
  status      String     @default("ACTIVE")
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookingId   String?
  booking     Booking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  contractId  String?
  contract    Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  invoices    Invoice[]
  quotations  Quotation[]
  title       String
  description String?
  projectType String?
  budget      Decimal?   @db.Decimal(12, 2)
  actualCost  Decimal?   @db.Decimal(12, 2)
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  assignedTo  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tasks       Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      String     @default("PENDING")
  priority    String     @default("MEDIUM")
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model TeamMember {
  id         String           @id @default(cuid())
  name       String
  role       String?
  department String?
  email      String?
  phone      String?
  active     Boolean          @default(true)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  tasks      WorkflowTask[]
  projects   WorkflowProject[] @relation("ProjectOwner")
}

model WorkflowProject {
  id          String             @id @default(cuid())
  title       String
  clientId    String?
  clientName  String?
  serviceType String?
  stage       String             @default("NEW_LEAD")
  priority    String             @default("NORMAL")
  ownerId     String?
  dueDate     DateTime?
  notes       String?
  quotationId String?
  contractId  String?
  invoiceId   String?
  bookingId   String?
  archived    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       TeamMember?        @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks       WorkflowTask[]
  approvals   WorkflowApproval[]
  deliveries  WorkflowDelivery[]
}

model WorkflowTask {
  id          String          @id @default(cuid())
  title       String
  description String?
  projectId   String?
  assigneeId  String?
  department  String?
  status      String          @default("TODO")
  priority    String          @default("NORMAL")
  dueDate     DateTime?
  notes       String?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    TeamMember?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model WorkflowApproval {
  id         String          @id @default(cuid())
  projectId  String?
  title      String
  clientName String?
  status     String          @default("NOT_SENT")
  sentDate   DateTime?
  dueDate    DateTime?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  project    WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model WorkflowDelivery {
  id              String          @id @default(cuid())
  projectId       String?
  title           String
  deliverableType String?
  deliveryLink    String?
  status          String          @default("PREPARING")
  deliveryDate    DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  project         WorkflowProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
